/* ===============================================
   STUDIQOO — Design Tokens (v2, light)
   Black & white foundation inspired by growth.cx,
   with Studiqoo's pink/gold accent kept for brand
   continuity. Friendly rounded display type, wavy
   dividers, doodle accents, comparison blocks.
=================================================== */
:root{
    --paper:#FFFFFF;
    --ink:#0E0E10;
    --soft:#F5F3EF;
    --soft-2:#ECE8E1;
    --muted:#6B6975;
    --line:rgba(14,14,16,.12);
    --line-strong:rgba(14,14,16,.22);
    --flare:#FF3B6E;
    --flare-dim:rgba(255,59,110,.10);
    --gold:#F2B544;
    --gold-dim:rgba(242,181,68,.16);

    --display:'Outfit', sans-serif;
    --body:'Inter', sans-serif;

    --shadow:0 20px 50px rgba(14,14,16,.08);
    --shadow-lg:0 30px 70px rgba(14,14,16,.16);
    --radius:26px;
    --ease:cubic-bezier(.16,1,.3,1);
}

/* Reset */
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
}

body{
    font-family:var(--body);
    color:var(--ink);
    background:var(--paper);
    overflow-x:hidden;
    line-height:1.7;
}

h1,h2,h3,h4{
    font-family:var(--display);
    font-weight:700;
    letter-spacing:-.02em;
    line-height:1.12;
}

img{
    width:100%;
    display:block;
}

a{
    text-decoration:none;
    color:inherit;
}

ul{
    list-style:none;
}

.container{
    width:min(1200px,90%);
    margin:auto;
}

em{
    font-style:normal;
    color:var(--flare);
}

@media (prefers-reduced-motion:reduce){
    *{
        animation-duration:0.01ms !important;
        animation-iteration-count:1 !important;
        transition-duration:0.01ms !important;
        scroll-behavior:auto !important;
    }
}

/* ================= NAVBAR ================= */

.navbar{
    position:fixed;
    top:0;
    width:100%;
    background:rgba(255,255,255,.85);
    backdrop-filter:blur(16px);
    border-bottom:1px solid var(--line);
    z-index:1000;
}

.nav-container{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:18px 0;
}

.logo{
    font-size:1.6rem;
    font-weight:800;
    font-family:var(--display);
    letter-spacing:-.02em;
    color:var(--ink);
}

.logo span{
    color:var(--flare);
}

.nav-links{
    display:flex;
    align-items:center;
    gap:32px;
}

.nav-links a{
    color:var(--ink);
    font-weight:500;
    font-size:.95rem;
    position:relative;
    padding-bottom:4px;
}

.nav-links a::after{
    content:"";
    position:absolute;
    left:0;
    bottom:0;
    width:0;
    height:2px;
    background:var(--flare);
    transition:width .4s var(--ease);
}

.nav-links a:hover::after,
.nav-links a.active::after{
    width:100%;
}

.nav-links a.active{
    color:var(--flare);
}

.nav-cta{
    background:var(--ink);
    color:#fff !important;
    padding:11px 22px;
    border-radius:999px;
    font-weight:600;
    transition:background .35s var(--ease), transform .35s var(--ease);
}

.nav-cta::after{
    display:none;
}

.nav-cta:hover{
    background:var(--flare);
    transform:translateY(-2px);
}

/* ================= DOODLES ================= */

.doodle{
    position:absolute;
    color:var(--ink);
    opacity:.55;
    pointer-events:none;
}

.doodle svg{
    width:100%;
    height:100%;
    display:block;
}

/* ================= HERO ================= */

.hero{
    min-height:100vh;
    display:flex;
    align-items:center;
    position:relative;
    background:var(--paper);
    padding-top:90px;
    overflow:hidden;
}

.hero-container{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:80px;
    align-items:center;
    position:relative;
    z-index:1;
}

.eyebrow{
    display:inline-block;
    font-family:var(--body);
    text-transform:uppercase;
    letter-spacing:.1em;
    font-size:.78rem;
    font-weight:700;
    color:var(--flare);
    background:var(--flare-dim);
    padding:7px 16px;
    border-radius:999px;
    margin-bottom:22px;
}

.hero-content h1{
    font-size:3.6rem;
    margin-bottom:25px;
    color:var(--ink);
}

.hero-content p{
    margin-bottom:35px;
    color:var(--muted);
    max-width:480px;
    font-size:1.05rem;
}

.gradient-text{
    background:linear-gradient(90deg,var(--flare),var(--gold));
    -webkit-background-clip:text;
    color:transparent;
}

.strike{
    position:relative;
    color:var(--muted);
}

.strike::after{
    content:"";
    position:absolute;
    left:-2%;
    right:-2%;
    top:50%;
    height:2px;
    background:var(--ink);
    transform:rotate(-2deg);
}

.hero-buttons{
    display:flex;
    gap:18px;
    flex-wrap:wrap;
}

.btn{
    padding:16px 32px;
    border-radius:999px;
    font-weight:600;
    transition:transform .45s var(--ease), box-shadow .45s var(--ease), background .35s var(--ease), color .35s var(--ease), border-color .35s var(--ease);
    display:inline-block;
    font-family:var(--body);
}

.btn-primary{
    background:var(--ink);
    color:#fff;
}

.btn-primary:hover{
    background:var(--flare);
    box-shadow:0 16px 35px -12px rgba(255,59,110,.5);
}

.btn-outline{
    border:2px solid var(--ink);
    color:var(--ink);
    padding:14px 30px;
}

.btn-outline:hover{
    border-color:var(--flare);
    color:var(--flare);
}

.btn:hover{
    transform:translateY(-4px);
}

.hero-illustration{
    position:relative;
}

.hero-image svg,
.about-image svg{
    width:100%;
    height:auto;
    display:block;
}

/* ================= WAVE DIVIDER ================= */

.wave-divider{
    position:relative;
    width:100%;
    line-height:0;
    background:var(--paper);
}

.wave-divider svg{
    width:100%;
    height:90px;
    display:block;
}

.wave-dot{
    position:absolute;
    border-radius:50%;
    background:var(--ink);
    pointer-events:none;
}

/* ================= MARQUEE ================= */

.marquee-section{
    border-top:1px solid var(--line);
    border-bottom:1px solid var(--line);
    background:var(--soft);
    padding:20px 0;
    overflow:hidden;
    -webkit-mask-image:linear-gradient(90deg,transparent,#000 10%,#000 90%,transparent);
    mask-image:linear-gradient(90deg,transparent,#000 10%,#000 90%,transparent);
}

.marquee-section:hover .marquee-track{
    animation-play-state:paused;
}

.marquee-track{
    display:flex;
    width:max-content;
    gap:50px;
    animation:scroll-marquee 28s linear infinite;
}

.marquee-track span{
    font-family:var(--body);
    text-transform:uppercase;
    letter-spacing:.1em;
    font-size:.8rem;
    font-weight:600;
    color:var(--muted);
    white-space:nowrap;
}

.marquee-track span i{
    color:var(--flare);
    margin-right:50px;
}

@keyframes scroll-marquee{
    from{ transform:translateX(0); }
    to{ transform:translateX(-50%); }
}

/* ================= RESPONSIVE ================= */

@media(max-width:992px){

    .hero-container{
        grid-template-columns:1fr;
    }

    .hero-content h1{
        font-size:2.6rem;
    }

    .nav-links{
        gap:15px;
    }
}

.about{
    padding:120px 0;
}

.about-container{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:80px;
    align-items:center;
}

.section-tag{
    color:var(--flare);
    font-family:var(--body);
    text-transform:uppercase;
    letter-spacing:.1em;
    font-weight:700;
    font-size:.78rem;
    display:block;
    margin-bottom:15px;
}

.about-content h2{
    font-size:2.4rem;
    margin-bottom:25px;
}

.about-content p{
    color:var(--muted);
    margin-bottom:15px;
}


/* ================= SERVICES ================= */

.services{
    background:var(--soft);
    padding:120px 0;
}

.section-header{
    text-align:center;
    margin-bottom:70px;
}

.section-header h2{
    font-size:2.4rem;
}

.section-header p{
    color:var(--muted);
    max-width:560px;
    margin:18px auto 0;
}

.services-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
    gap:22px;
}

.service-card{
    background:var(--paper);
    border:1px solid var(--line);
    padding:38px;
    border-radius:var(--radius);
    transition:transform .5s var(--ease), border-color .4s var(--ease), box-shadow .4s var(--ease);
}

.service-card:hover{
    transform:translateY(-8px);
    border-color:var(--ink);
    box-shadow:var(--shadow);
}

.service-card i{
    font-size:1.5rem;
    color:#fff;
    margin-bottom:20px;
    width:50px;
    height:50px;
    border-radius:14px;
    background:var(--ink);
    display:flex;
    align-items:center;
    justify-content:center;
}

.service-card h3{
    margin-bottom:12px;
    font-size:1.2rem;
}

.service-card p{
    color:var(--muted);
    font-size:.95rem;
}


/* Responsive */

@media(max-width:992px){

    .about-container{
        grid-template-columns:1fr;
    }

}

/* ================= COMPARE BLOCK ================= */

.compare{
    padding:120px 0;
}

.compare-grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:30px;
}

.compare-card{
    border-radius:var(--radius);
    padding:50px 42px;
}

.compare-card.light{
    background:var(--paper);
    border:2px solid var(--line-strong);
}

.compare-card.dark{
    background:var(--ink);
    color:#fff;
}

.compare-card h3{
    margin-bottom:30px;
    font-size:1.4rem;
}

.compare-card.dark h3{
    color:#fff;
}

.compare-card ul li{
    display:flex;
    align-items:flex-start;
    gap:14px;
    margin-bottom:20px;
    font-size:.98rem;
}

.compare-card.light ul li i{
    color:var(--ink);
    background:var(--soft-2);
    width:22px;
    height:22px;
    min-width:22px;
    border-radius:50%;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:.65rem;
    margin-top:3px;
}

.compare-card.dark ul li i{
    color:var(--ink);
    background:var(--gold);
    width:22px;
    height:22px;
    min-width:22px;
    border-radius:50%;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:.65rem;
    margin-top:3px;
}

.compare-card.light ul li span{
    color:var(--muted);
}

.compare-card.dark ul li span{
    color:rgba(255,255,255,.82);
}

@media(max-width:900px){
    .compare-grid{
        grid-template-columns:1fr;
    }
}

/* ================= WHY US ================= */

.why-us{
    padding:120px 0;
    background:var(--soft);
}

.why-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
    gap:22px;
}

.why-card{
    background:var(--paper);
    border:1px solid var(--line);
    padding:38px;
    border-radius:var(--radius);
    transition:transform .5s var(--ease), border-color .4s var(--ease), box-shadow .4s var(--ease);
}

.why-card:hover{
    transform:translateY(-8px);
    border-color:var(--gold);
    box-shadow:var(--shadow);
}

.number{
    font-family:var(--display);
    color:var(--flare);
    font-size:1.7rem;
    font-weight:800;
    margin-bottom:18px;
}


/* ================= STATS ================= */

.stats{
    padding:90px 0;
    border-top:1px solid var(--line);
    border-bottom:1px solid var(--line);
}

.stats-box{
    display:grid;
    grid-template-columns:repeat(4,1fr);
}

.stat-card{
    text-align:center;
    padding:0 20px;
    border-right:1px solid var(--line);
}

.stat-card:last-child{
    border-right:none;
}

.stat-card h2{
    font-size:2.8rem;
    background:linear-gradient(90deg,var(--flare),var(--gold));
    -webkit-background-clip:text;
    color:transparent;
}

.stat-card p{
    color:var(--muted);
    font-size:.85rem;
    text-transform:uppercase;
    letter-spacing:.06em;
    margin-top:8px;
}


@media(max-width:992px){
    .stats-box{ grid-template-columns:1fr 1fr; }
    .stat-card:nth-child(2){ border-right:none; }
}

@media(max-width:600px){
    .stats-box{ grid-template-columns:1fr; }
    .stat-card{ border-right:none !important; border-bottom:1px solid var(--line); padding-bottom:25px; margin-bottom:25px; }
    .stat-card:last-child{ border-bottom:none; margin-bottom:0; padding-bottom:0; }
}

/* ================= CLIENTS ================= */

.clients{
    padding:120px 0;
}

.clients-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(190px,1fr));
    gap:20px;
}

.client-card{
    background:var(--paper);
    border:1px solid var(--line);
    border-radius:20px;
    padding:36px 20px;
    display:flex;
    align-items:center;
    justify-content:center;
    font-family:var(--display);
    font-weight:700;
    font-size:1.25rem;
    color:var(--ink);
    transition:transform .5s var(--ease), border-color .4s var(--ease), box-shadow .4s var(--ease);
    text-align:center;
    position:relative;
}

.client-card:hover{
    transform:translateY(-8px);
    border-color:var(--ink);
    box-shadow:var(--shadow);
}

.client-card.featured{
    background:var(--ink);
    border-color:var(--ink);
}

.client-card.featured span{
    background:linear-gradient(90deg,var(--gold),#fff7e8);
    -webkit-background-clip:text;
    color:transparent;
}

.client-card.featured::before{
    content:"Featured Partner";
    position:absolute;
    top:-13px;
    left:50%;
    transform:translateX(-50%);
    background:var(--flare);
    color:#fff;
    font-size:.62rem;
    padding:5px 14px;
    border-radius:999px;
    font-family:var(--body);
    font-weight:700;
    text-transform:uppercase;
    letter-spacing:.05em;
    white-space:nowrap;
}

/* ================= PORTFOLIO (case study tiles) ================= */

.portfolio{
    padding:120px 0;
    background:var(--soft);
}

.portfolio-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
    gap:22px;
}

.portfolio-card{
    background:var(--paper);
    border:1px solid var(--line);
    border-radius:var(--radius);
    overflow:hidden;
    transition:transform .5s var(--ease), box-shadow .4s var(--ease);
}

.portfolio-card:hover{
    transform:translateY(-8px);
    box-shadow:var(--shadow-lg);
}

.portfolio-tile{
    height:180px;
    display:flex;
    align-items:center;
    justify-content:center;
    position:relative;
    overflow:hidden;
}

.portfolio-tile h4{
    color:#fff;
    font-size:2.6rem;
    position:relative;
    z-index:1;
    opacity:.95;
}

.portfolio-tile::after{
    content:"";
    position:absolute;
    inset:0;
    background-image:radial-gradient(circle, rgba(255,255,255,.18) 1px, transparent 1px);
    background-size:18px 18px;
}

.tile-1{ background:linear-gradient(135deg,#FF3B6E,#FF8A5C); }
.tile-2{ background:linear-gradient(135deg,#0E0E10,#3A3A40); }
.tile-3{ background:linear-gradient(135deg,#F2B544,#FF3B6E); }

.portfolio-content{
    padding:30px;
}

.portfolio-content h3{
    margin-bottom:15px;
}

.portfolio-content p{
    color:var(--muted);
    margin-bottom:20px;
}

.portfolio-content span{
    color:var(--flare);
    font-weight:700;
    font-size:.85rem;
    text-transform:uppercase;
    letter-spacing:.04em;
}


/* ================= TESTIMONIALS ================= */

.testimonials{
    padding:120px 0;
}

.testimonial-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
    gap:22px;
}

.testimonial-card{
    background:var(--paper);
    border:1px solid var(--line);
    padding:38px;
    border-radius:var(--radius);
    transition:transform .5s var(--ease), box-shadow .4s var(--ease);
}

.testimonial-card:hover{
    transform:translateY(-8px);
    box-shadow:var(--shadow);
}

.testimonial-card p{
    color:var(--muted);
    margin-bottom:25px;
}

.testimonial-card h4{
    margin-bottom:4px;
}

.testimonial-card span{
    color:var(--flare);
    font-size:.85rem;
    font-weight:600;
}

/* ================= PRICING ================= */

.pricing{
    padding:120px 0;
    background:var(--soft);
}

.pricing-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
    gap:22px;
}

.pricing-card{
    background:var(--paper);
    border:1px solid var(--line);
    padding:40px;
    border-radius:var(--radius);
    text-align:center;
    transition:transform .5s var(--ease), box-shadow .4s var(--ease);
}

.pricing-card:hover{
    transform:translateY(-8px);
    box-shadow:var(--shadow);
}

.featured{
    border:2px solid var(--ink);
    position:relative;
}

.price{
    font-size:2.3rem;
    font-weight:800;
    font-family:var(--display);
    margin:22px 0;
}

.price span{
    font-size:1rem;
    font-weight:400;
    color:var(--muted);
}

.pricing-card ul{
    margin-bottom:30px;
}

.pricing-card ul li{
    color:var(--muted);
    padding:8px 0;
}


/* ================= CONTACT ================= */

.contact{
    padding:120px 0;
}

.contact-form{
    max-width:700px;
    margin:auto;

    display:flex;
    flex-direction:column;
    gap:18px;
}

.contact-form input,
.contact-form textarea{
    padding:17px 20px;
    border:1px solid var(--line-strong);
    background:var(--paper);
    color:var(--ink);
    border-radius:16px;
    font-family:var(--body);
}

.contact-form input::placeholder,
.contact-form textarea::placeholder{
    color:var(--muted);
}

.contact-form input:focus,
.contact-form textarea:focus{
    outline:none;
    border-color:var(--flare);
}


/* ================= FOOTER ================= */

.footer{
    background:var(--ink);
    color:#fff;
    padding:90px 0 40px;
}

.footer-grid{
    display:grid;
    grid-template-columns:1.4fr repeat(4,1fr);
    gap:30px;
    padding-bottom:60px;
}

.footer-brand h2{
    font-size:1.7rem;
    margin-bottom:14px;
}

.footer-brand p{
    color:rgba(255,255,255,.6);
    max-width:280px;
    font-size:.92rem;
}

.footer-col h4{
    font-family:var(--body);
    font-size:.85rem;
    text-transform:uppercase;
    letter-spacing:.06em;
    margin-bottom:18px;
    color:rgba(255,255,255,.5);
}

.footer-col ul li{
    margin-bottom:12px;
}

.footer-col ul li a{
    color:rgba(255,255,255,.8);
    font-size:.92rem;
    transition:color .3s var(--ease);
}

.footer-col ul li a:hover{
    color:var(--flare);
}

.footer-bottom{
    border-top:1px solid rgba(255,255,255,.12);
    padding-top:30px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    flex-wrap:wrap;
    gap:15px;
}

.footer span{
    color:var(--flare);
}

.copyright{
    color:rgba(255,255,255,.55);
    font-size:.85rem;
}

.footer-socials{
    display:flex;
    gap:16px;
}

.footer-socials a{
    width:38px;
    height:38px;
    border-radius:50%;
    border:1px solid rgba(255,255,255,.2);
    display:flex;
    align-items:center;
    justify-content:center;
    color:#fff;
    transition:background .3s var(--ease), border-color .3s var(--ease);
}

.footer-socials a:hover{
    background:var(--flare);
    border-color:var(--flare);
}

@media(max-width:900px){
    .footer-grid{
        grid-template-columns:1fr 1fr;
    }
}

@media(max-width:560px){
    .footer-grid{
        grid-template-columns:1fr;
    }
    .footer-bottom{
        flex-direction:column;
        align-items:flex-start;
    }
}


/* ================= ANIMATION ================= */

.hidden{
    opacity:0;
    transform:translateY(40px);
    transition:all .9s var(--ease);
}

.show{
    opacity:1;
    transform:translateY(0);
}

.services-grid > *:nth-child(1),
.why-grid > *:nth-child(1),
.pricing-grid > *:nth-child(1),
.portfolio-grid > *:nth-child(1),
.testimonial-grid > *:nth-child(1),
.clients-grid > *:nth-child(1){ transition-delay:.05s; }

.services-grid > *:nth-child(2),
.why-grid > *:nth-child(2),
.pricing-grid > *:nth-child(2),
.portfolio-grid > *:nth-child(2),
.testimonial-grid > *:nth-child(2),
.clients-grid > *:nth-child(2){ transition-delay:.12s; }

.services-grid > *:nth-child(3),
.why-grid > *:nth-child(3),
.pricing-grid > *:nth-child(3),
.portfolio-grid > *:nth-child(3),
.clients-grid > *:nth-child(3){ transition-delay:.19s; }

.services-grid > *:nth-child(4),
.why-grid > *:nth-child(4),
.clients-grid > *:nth-child(4){ transition-delay:.26s; }

.services-grid > *:nth-child(5),
.clients-grid > *:nth-child(5){ transition-delay:.33s; }
.clients-grid > *:nth-child(6){ transition-delay:.4s; }
.clients-grid > *:nth-child(7){ transition-delay:.47s; }

/* ================= FAQ ================= */

.faq{
    padding:120px 0;
    background:var(--soft);
}

.faq-item{
    background:var(--paper);
    border:1px solid var(--line);
    margin-bottom:14px;
    border-radius:18px;
    overflow:hidden;
    transition:border-color .3s var(--ease);
}

.faq-item:hover{
    border-color:var(--line-strong);
}

.faq-question{
    width:100%;
    padding:24px 26px;
    background:none;
    border:none;
    text-align:left;
    cursor:pointer;
    font-size:1rem;
    font-weight:600;
    color:var(--ink);
    font-family:var(--body);
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:20px;
}

.faq-question::after{
    content:"\2304";
    font-size:1.3rem;
    color:var(--muted);
    transition:transform .35s var(--ease);
    flex-shrink:0;
}

.faq-question.open::after{
    transform:rotate(180deg);
    color:var(--flare);
}

.faq-answer{
    display:none;
    padding:0 26px 26px;
    color:var(--muted);
}


/* ================= BACK TO TOP ================= */

#topBtn{
    position:fixed;
    bottom:25px;
    right:25px;

    width:52px;
    height:52px;

    border:none;
    border-radius:50%;

    background:var(--ink);
    color:#fff;

    cursor:pointer;
    display:none;

    font-size:20px;
    transition:background .3s var(--ease), transform .3s var(--ease);
}

#topBtn:hover{
    background:var(--flare);
    transform:translateY(-4px);
}

/* ================= MOBILE MENU ================= */

.menu-toggle{
    display:none;
    font-size:1.5rem;
    cursor:pointer;
    color:var(--ink);
}

@media(max-width:768px){

    .menu-toggle{
        display:block;
    }

    /* nav-links mobile handled in MOBILE RESPONSIVE section below */

    .nav-links.active{
        display:flex;
    }

}

/* ================= SERVICE BLOCKS (services.html) ================= */

.service-block{
    padding:60px 0;
    border-bottom:1px solid var(--line);
}

.service-block:last-child{
    border-bottom:none;
}

.service-block-header{
    display:flex;
    align-items:center;
    gap:18px;
    margin-bottom:14px;
    flex-wrap:wrap;
}

.service-block-icon{
    width:54px;
    height:54px;
    min-width:54px;
    border-radius:16px;
    background:var(--ink);
    color:#fff;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:1.3rem;
}

.service-block.featured .service-block-icon{
    background:linear-gradient(135deg,var(--flare),var(--gold));
}

.service-block h3{
    font-size:1.6rem;
}

.star-badge{
    background:var(--flare-dim);
    color:var(--flare);
    font-size:.68rem;
    font-weight:700;
    padding:6px 14px;
    border-radius:999px;
    text-transform:uppercase;
    letter-spacing:.05em;
}

.service-block > p{
    color:var(--muted);
    max-width:640px;
    margin-bottom:24px;
}

.service-checklist{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(230px,1fr));
    gap:6px 30px;
}

.service-checklist li{
    display:flex;
    align-items:flex-start;
    gap:10px;
    color:var(--muted);
    padding:7px 0;
    font-size:.95rem;
}

.service-checklist li i{
    color:var(--flare);
    margin-top:5px;
    font-size:.7rem;
}

/* ================= PREMIUM CARD ================= */

.premium-section{
    padding:100px 0 60px;
}

.premium-card{
    background:var(--ink);
    color:#fff;
    border-radius:32px;
    padding:60px;
    position:relative;
    overflow:hidden;
    display:grid;
    grid-template-columns:1.3fr 1fr;
    gap:50px;
    align-items:center;
}

.premium-card::before{
    content:"";
    position:absolute;
    width:380px;
    height:380px;
    border-radius:50%;
    background:radial-gradient(circle, var(--flare), transparent 70%);
    opacity:.25;
    top:-120px;
    right:-100px;
    filter:blur(30px);
}

.premium-card .eyebrow{
    background:rgba(255,255,255,.1);
    color:var(--gold);
}

.premium-card h2{
    color:#fff;
    font-size:2.1rem;
    margin-bottom:18px;
    position:relative;
    z-index:1;
}

.premium-card p{
    color:rgba(255,255,255,.75);
    margin-bottom:0;
    position:relative;
    z-index:1;
}

.premium-list{
    position:relative;
    z-index:1;
}

.premium-list li{
    display:flex;
    align-items:center;
    gap:12px;
    padding:10px 0;
    border-bottom:1px solid rgba(255,255,255,.1);
    color:rgba(255,255,255,.9);
    font-size:.95rem;
}

.premium-list li:last-child{
    border-bottom:none;
}

.premium-list li i{
    color:var(--gold);
}

@media(max-width:900px){
    .premium-card{
        grid-template-columns:1fr;
        padding:40px 30px;
    }
}

/* ================= PROCESS ================= */

.process{
    padding:120px 0;
}

.process-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
    gap:22px;
    position:relative;
}

.process-step{
    background:var(--paper);
    border:1px solid var(--line);
    padding:36px 28px;
    border-radius:var(--radius);
    text-align:center;
    transition:transform .5s var(--ease), border-color .4s var(--ease), box-shadow .4s var(--ease);
}

.process-step:hover{
    transform:translateY(-8px);
    border-color:var(--gold);
    box-shadow:var(--shadow);
}

.process-step h3{
    margin-bottom:10px;
    font-size:1.15rem;
}

.process-step p{
    color:var(--muted);
    font-size:.92rem;
}

/* ================= SERVICES CTA ================= */

.services-cta{
    padding:110px 0;
    text-align:center;
    background:linear-gradient(120deg,var(--flare),var(--gold));
}

.services-cta h2{
    font-size:2.3rem;
    margin-bottom:18px;
    color:var(--ink);
}

.services-cta p{
    color:rgba(14,14,16,.78);
    margin-bottom:28px;
    max-width:600px;
    margin-left:auto;
    margin-right:auto;
    font-weight:500;
}

.services-cta .btn-primary{
    background:var(--ink);
    color:#fff;
}

.services-cta .btn-primary:hover{
    background:#fff;
    color:var(--ink);
}


/* ================= VIDEO SECTION ================= */

.video-section{
    padding:120px 0;
    background:var(--soft);
}

.video-wrapper{
    max-width:900px;
    margin:0 auto;
    border-radius:var(--radius);
    overflow:hidden;
    box-shadow:var(--shadow-lg);
    border:1px solid var(--line);
    position:relative;
    aspect-ratio:16/9;
    background:var(--paper);
}

.video-wrapper iframe,
.video-wrapper video{
    width:100%;
    height:100%;
    border:none;
    display:block;
}

.video-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:22px;
    margin-top:50px;
}

.video-card{
    background:var(--paper);
    border:1px solid var(--line);
    border-radius:var(--radius);
    overflow:hidden;
    transition:transform .5s var(--ease), border-color .4s var(--ease);
}

.video-card:hover{
    transform:translateY(-8px);
    border-color:var(--flare);
}

.video-card .video-wrapper{
    border-radius:0;
    box-shadow:none;
    border:none;
    margin:0;
    max-width:none;
}

.video-card-content{
    padding:22px;
}

.video-card-content h4{
    margin-bottom:6px;
}

.video-card-content p{
    color:var(--muted);
    font-size:.92rem;
}


/* ================================================
   MOBILE RESPONSIVE — comprehensive pass
   Covers all breakpoints: 768px (tablet/phablet)
   and 480px (small phones)
================================================ */

/* ---- Navbar ---- */
@media(max-width:768px){

    .nav-cta{ display:none; }

    .nav-links{
        position:fixed;
        top:0;
        left:0;
        width:100%;
        height:100vh;
        background:var(--paper);
        border:none;

        flex-direction:column;
        align-items:center;
        justify-content:center;

        gap:28px;
        padding:0;

        display:none;
        z-index:999;
    }

    .nav-links.active{
        display:flex;
    }

    .nav-links a{
        font-size:1.3rem;
        font-weight:700;
    }

    .menu-toggle{
        display:block;
        z-index:1001;
        position:relative;
    }

    .logo{
        z-index:1001;
        position:relative;
    }

}

/* ---- Hero ---- */
@media(max-width:992px){

    .hero{
        padding-top:100px;
        padding-bottom:60px;
        min-height:auto !important;
    }

    .hero-container{
        grid-template-columns:1fr !important;
        gap:40px;
        text-align:center;
    }

    .hero-content h1{
        font-size:2.4rem;
    }

    .hero-content p{
        max-width:100%;
        margin-left:auto;
        margin-right:auto;
    }

    .hero-buttons{
        justify-content:center;
    }

    .hero-illustration{
        max-width:480px;
        margin:0 auto;
    }

    .doodle{
        display:none;
    }

}

@media(max-width:480px){

    .hero-content h1{
        font-size:2rem;
    }

    .eyebrow{
        font-size:.72rem;
    }

}

/* ---- About two-col ---- */
@media(max-width:992px){

    .about-container{
        grid-template-columns:1fr !important;
        gap:40px;
    }

    .about-image{
        max-width:460px;
        margin:0 auto;
    }

}

/* ---- Sections general padding ---- */
@media(max-width:768px){

    .about,
    .services,
    .compare,
    .clients,
    .portfolio,
    .testimonials,
    .pricing,
    .contact,
    .faq,
    .why-us,
    .stats,
    .process,
    .video-section,
    .premium-section{
        padding:80px 0;
    }

    .section-header{
        margin-bottom:44px;
    }

    .section-header h2{
        font-size:1.9rem;
    }

}

@media(max-width:480px){

    .about,
    .services,
    .compare,
    .clients,
    .portfolio,
    .testimonials,
    .pricing,
    .contact,
    .faq,
    .why-us,
    .stats,
    .process,
    .video-section,
    .premium-section{
        padding:60px 0;
    }

    .section-header h2{
        font-size:1.65rem;
    }

}

/* ---- Services grid ---- */
@media(max-width:600px){

    .services-grid{
        grid-template-columns:1fr;
    }

}

/* ---- Compare cards ---- */
@media(max-width:768px){

    .compare-grid{
        grid-template-columns:1fr;
    }

    .compare-card{
        padding:38px 28px;
    }

}

/* ---- Stats strip ---- */
@media(max-width:768px){

    .stats{
        padding:60px 0;
    }

    .stats-box{
        grid-template-columns:1fr 1fr;
        gap:30px;
        border:none;
    }

    .stat-card{
        border-right:none !important;
        border-bottom:1px solid var(--line);
        padding-bottom:24px;
    }

    .stat-card:nth-child(odd){
        border-right:1px solid var(--line) !important;
    }

    .stat-card:last-child,
    .stat-card:nth-last-child(2):nth-child(odd){
        border-bottom:none;
    }

}

@media(max-width:480px){

    .stats-box{
        grid-template-columns:1fr;
    }

    .stat-card{
        border-right:none !important;
    }

    .stat-card:nth-child(odd){
        border-right:none !important;
    }

    .stat-card:last-child{
        border-bottom:none;
    }

}

/* ---- Clients grid ---- */
@media(max-width:600px){

    .clients-grid{
        grid-template-columns:1fr 1fr;
    }

}

@media(max-width:380px){

    .clients-grid{
        grid-template-columns:1fr;
    }

}

/* ---- Portfolio grid ---- */
@media(max-width:680px){

    .portfolio-grid{
        grid-template-columns:1fr;
    }

}

/* ---- Testimonials ---- */
@media(max-width:680px){

    .testimonial-grid{
        grid-template-columns:1fr;
    }

}

/* ---- Pricing ---- */
@media(max-width:900px){

    .pricing-grid{
        grid-template-columns:1fr;
        max-width:480px;
        margin:0 auto;
    }

}

/* ---- Process ---- */
@media(max-width:600px){

    .process-grid{
        grid-template-columns:1fr;
    }

}

/* ---- Premium card ---- */
@media(max-width:768px){

    .premium-card{
        grid-template-columns:1fr;
        padding:38px 28px;
    }

    .premium-card h2{
        font-size:1.7rem;
    }

}

/* ---- Services page service-blocks ---- */
@media(max-width:600px){

    .service-checklist{
        grid-template-columns:1fr;
    }

    .service-block{
        padding:44px 0;
    }

    .service-block-header h3{
        font-size:1.3rem;
    }

}

/* ---- Video grid ---- */
@media(max-width:680px){

    .video-grid{
        grid-template-columns:1fr;
    }

}

/* ---- Wave divider ---- */
@media(max-width:768px){

    .wave-divider svg{
        height:55px;
    }

    .wave-dot{
        display:none;
    }

}

/* ---- Contact form ---- */
@media(max-width:600px){

    .contact-form{
        gap:14px;
    }

    .contact-form input,
    .contact-form textarea{
        padding:14px 16px;
        font-size:.95rem;
    }

}

/* ---- Services CTA ---- */
@media(max-width:600px){

    .services-cta{
        padding:70px 0;
    }

    .services-cta h2{
        font-size:1.7rem;
    }

}

/* ---- Buttons ---- */
@media(max-width:480px){

    .btn{
        padding:14px 26px;
        font-size:.95rem;
    }

    .hero-buttons{
        flex-direction:column;
        align-items:center;
    }

}

/* ---- Footer ---- */
@media(max-width:900px){

    .footer-grid{
        grid-template-columns:1fr 1fr;
        gap:40px;
    }

    .footer-brand{
        grid-column:1/-1;
    }

}

@media(max-width:560px){

    .footer-grid{
        grid-template-columns:1fr;
    }

    .footer-brand{
        grid-column:auto;
    }

    .footer-bottom{
        flex-direction:column;
        align-items:flex-start;
        gap:18px;
    }

}
